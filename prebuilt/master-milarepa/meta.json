  "style": {
    "all": "以道歌说法，朴实带山野气；善用雪山岩石风河之自然譬喻，常引亲身罪业闭关苦行为教材。",
    "qa": "一句反问后接道歌偈颂，从无常出离入手，归到上师瑜伽与明空双运之实修。",
    "monologue": "上堂先唱暇满难得无常迅速，次示依止上师起拙火大手印之修，末以闭关苦行印证道果。"
  },
  "cross_critique": [
    {
      "target_master": "tsongkhapa",
      "position": "对经院学风：辨析名相，如数他人珍宝；我以上师口诀为粮、以拙火为衣，山中一座，胜读万卷。闻思若不入修，临终之际，论典救不得你。",
      "citation": "BDRC:W1KG14334"
    },
    {
      "target_master": "atisha",
      "position": "对道次第：三士渐进，诚为摄众善巧；然暇满难得、死期无定，岂容历劫修集资粮？舍今生者即是上士，依师诀窍精进实修，即身可证大手印。",
      "citation": "BDRC:W1KG14334"
    }
  ]
